rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userOrgRoles() {
      return userDoc().orgRoles;
    }

    function hasOrgAccess(orgId) {
      let roles = userOrgRoles();
      return orgId in roles || '*' in roles;
    }

    function hasRole(orgId, role) {
      let roles = userOrgRoles();
      let orgRoles = orgId in roles ? roles[orgId] : ('*' in roles ? roles['*'] : []);
      return role in orgRoles || 'ADMIN' in orgRoles || 'admin' in orgRoles;
    }

    function isAdmin(orgId) {
      return hasRole(orgId, 'ADMIN');
    }

    // ─── Users ────────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ─── Requests (workflow) ──────────────────────────────────────────────────
    // All mutations go through Cloud Functions; clients get read access if they
    // belong to the org (requestor, approver, or finance role).

    match /requests/{requestId} {
      allow read: if isAuthenticated() && hasOrgAccess(resource.data.orgId);
      allow write: if false;
    }

    // ─── Line Items ───────────────────────────────────────────────────────────

    match /lineItems/{lineItemId} {
      allow read: if isAuthenticated() && hasOrgAccess(resource.data.orgId);
      allow write: if false;
    }

    // ─── Files ────────────────────────────────────────────────────────────────

    match /files/{fileId} {
      allow read: if isAuthenticated() && hasOrgAccess(resource.data.orgId);
      allow write: if false;
    }

    // ─── Tokens ───────────────────────────────────────────────────────────────
    // Readable without auth so unauthenticated approvers can validate their token.
    // Write only via Cloud Functions.

    match /tokens/{tokenId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Admin Departments ────────────────────────────────────────────────────

    match /adminDepts/{deptId} {
      allow read: if isAuthenticated() && (hasOrgAccess(resource.data.organizationId) || hasOrgAccess(resource.data.orgId));
      allow write: if false;
    }

    // ─── Escalation Rules ─────────────────────────────────────────────────────

    match /escalationRules/{ruleId} {
      allow read: if isAuthenticated() && hasOrgAccess(resource.data.orgId);
      allow write: if false;
    }

    // ─── Counters ─────────────────────────────────────────────────────────────

    match /counters/{counterId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ─── QB Payment Accounts ─────────────────────────────────────────────────

    match /qbPaymentAccounts/{accountId} {
      allow read: if isAuthenticated() && hasOrgAccess(resource.data.orgId);
      allow write: if false;
    }

    // ─── Vendors ──────────────────────────────────────────────────────────────

    match /vendors/{vendorId} {
      allow read: if isAuthenticated() && hasOrgAccess(resource.data.orgId);
      allow write: if false;
    }

    // ─── Vendor Setup Requests ────────────────────────────────────────────────

    match /vendorSetupRequests/{requestId} {
      allow read: if isAuthenticated() && hasOrgAccess(resource.data.orgId);
      allow write: if false;
    }

    // ─── Vendor Intakes ───────────────────────────────────────────────────────
    // Publicly readable so vendor can load their intake form via token link.

    match /vendorIntakes/{intakeId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Org Roles ────────────────────────────────────────────────────────────

    match /orgRoles/{roleId} {
      allow read: if isAuthenticated() && hasOrgAccess(resource.data.orgId);
      allow write: if false;
    }

    // ─── Budgets ──────────────────────────────────────────────────────────────

    match /budgets/{budgetId} {
      allow read: if isAuthenticated() && hasOrgAccess(resource.data.orgId);
      allow write: if false;
    }

    // ─── Mail Queue (Trigger Email extension) ─────────────────────────────────

    match /mail/{mailId} {
      allow read, write: if false;
    }

    // ─── Legacy collections (existing SaaS scaffold) ──────────────────────────

    match /tenants/{tenantId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /organizations/{orgId} {
      allow read: if isAuthenticated() && hasOrgAccess(orgId);
      allow write: if false;
    }

    match /purchaseRequests/{requestId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /expenseReports/{reportId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /expenseLineItems/{lineItemId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /approvals/{approvalId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /accountingExports/{exportId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /chartOfAccounts/{accountId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /journalEntries/{entryId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /funds/{fundId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /categories/{categoryId} {
      allow read: if isAuthenticated() && hasOrgAccess(resource.data.orgId);
      allow write: if false;
    }

    match /categoryBudgets/{id} {
      allow read: if isAuthenticated() && (hasOrgAccess(resource.data.organizationId) || hasOrgAccess(resource.data.orgId));
      allow write: if false;
    }

    match /workflowSettings/{id} {
      allow read: if isAuthenticated() && hasOrgAccess(resource.data.orgId);
      allow write: if false;
    }

    match /adminAuditLogs/{id} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

  }
}
