rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Receipt uploads ──────────────────────────────────────────────────────
    // Path: receipts/{orgId}/{requestId}/{filename}
    // Authenticated users can upload receipts; max 20 MB, images/PDFs only.

    match /receipts/{orgId}/{requestId}/{filename} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf|application/vnd.openxmlformats.*|text/.*');
      allow delete: if request.auth != null;
      allow update: if false;
    }

    // ─── Vendor W9 / intake documents ────────────────────────────────────────
    // Path: vendor-intakes/{vendorSetupRequestId}/{filename}

    match /vendor-intakes/{vendorSetupRequestId}/{filename} {
      allow read: if request.auth != null;
      allow create: if request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf|application/vnd.openxmlformats.*');
      allow delete: if request.auth != null;
      allow update: if false;
    }

    // ─── Accounting exports ───────────────────────────────────────────────────
    // Written only by Cloud Functions (admin SDK).

    match /exports/{exportId}/{filename} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Block everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }

  }
}
