rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ─── Expense request attachments ──────────────────────────────────────────
    // Authenticated users can read/write files within the expense-app/requests prefix.
    // File paths: expense-app/requests/{requestId}/{filename}

    match /expense-app/requests/{requestId}/{filename} {
      // Any authenticated user can read (tenant filtering is enforced by Firestore rules
      // on the parent request document — file URLs are obtained only after reading the request).
      allow read: if request.auth != null;

      // Only authenticated users can upload; max 20 MB per file.
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf|application/vnd.openxmlformats.*|text/.*');

      // Deletion allowed only by the uploader or via Cloud Functions (admin SDK).
      allow delete: if request.auth != null;
    }

    // ─── Accounting exports ───────────────────────────────────────────────────
    // CSV/Excel exports generated by Cloud Functions.

    match /expense-app/exports/{exportId}/{filename} {
      allow read: if request.auth != null;
      allow write, delete: if false; // written only by Cloud Functions
    }

    // Block all other paths by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }

  }
}
